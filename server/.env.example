# Required Environment Variables
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=upaci
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_URL=postgresql://postgres:your_password_here@localhost:5432/upaci
DB_SSL=false
DB_MAX_CONNECTIONS=20

# Redis Configuration (Upstash Redis with TLS)
# Get credentials from: https://console.upstash.com/redis
REDIS_URL=rediss://your-upstash-endpoint.upstash.io:6379
REDIS_TOKEN=your-upstash-token-here
REDIS_TLS=true
REDIS_MAX_RETRIES=3

# JWT Authentication
# IMPORTANT: Generate a secure secret key with at least 64 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-must-be-at-least-64-characters-long
# JWT token expiry: 15 minutes (900 seconds) per AC1 and AC3
JWT_EXPIRES_IN=15m
# JWT refresh token expiry (optional - for future use)
JWT_REFRESH_EXPIRES_IN=7d
# JWT algorithm (HS256 recommended)
JWT_ALGORITHM=HS256

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OpenAI Configuration (for AI features - US_041)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# Email Configuration (for notifications - US_016)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@clinic.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@clinic.com

# Twilio Configuration (for SMS reminders - US_016)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Prometheus Metrics Configuration (for monitoring - US_005)
# Enable/disable metrics collection
METRICS_ENABLED=true
# Enable basic authentication for /metrics endpoint (recommended for production)
METRICS_AUTH_ENABLED=true
# Basic auth credentials (change in production)
METRICS_AUTH_USER=admin
METRICS_AUTH_PASS=change-this-secure-password-in-production
# IP whitelist for metrics endpoint (comma-separated, defaults to localhost)
# Example: 127.0.0.1,::1,10.0.0.5,192.168.1.100
METRICS_IP_WHITELIST=127.0.0.1,::1

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# Calendar Sync Configuration (US_017 - OAuth2 PKCE Flow)
# Google Calendar OAuth2
# Setup: https://console.cloud.google.com/ -> Create OAuth2 credentials
GOOGLE_CLIENT_ID=your-google-client-id-from-cloud-console
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/google/callback

# Microsoft Outlook OAuth2
# Setup: https://portal.azure.com/ -> Azure AD -> App registrations
MICROSOFT_CLIENT_ID=your-microsoft-client-id-from-azure-ad
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/calendar/outlook/callback

# Calendar Token Encryption
# Generate secure key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CALENDAR_TOKEN_ENCRYPTION_KEY=your-32-byte-base64-encoded-encryption-key-here-change-in-production

# Calendar Sync Feature Flag
CALENDAR_SYNC_ENABLED=true
