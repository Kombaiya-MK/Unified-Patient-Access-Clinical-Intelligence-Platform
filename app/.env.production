# Production API Configuration
# Set VITE_API_URL to your Render backend URL (e.g., https://upaci-api.onrender.com/api)
# This MUST be set in Vercel environment variables at build time
VITE_API_URL=/api

# WebSocket URL (e.g., wss://upaci-api.onrender.com)
# This MUST be set in Vercel environment variables at build time
VITE_WS_URL=

# Base path
VITE_BASE_PATH=/

# Application Settings
VITE_APP_NAME=Clinical Appointment Platform
VITE_APP_VERSION=1.0.0
