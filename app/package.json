{
  "name": "clinical-appointment-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "tokens:build": "style-dictionary build --config config/style-dictionary.config.js",
    "tokens:validate": "node src/design-tokens/scripts/validate-contrast.js",
    "tokens:watch": "node --watch-path=src/styles/tokens -e json -e npm run tokens:build",
    "tokens:version": "node scripts/version-tokens.js",
    "tokens:changelog": "node scripts/generate-token-changelog.js",
    "tokens:changelog:write": "node scripts/generate-token-changelog.js --write",
    "version:tokens": "node scripts/version-tokens.js",
    "predev": "npm run tokens:build",
    "dev": "vite",
    "prebuild": "npm run tokens:build",
    "build": "tsc -b && vite build",
    "build:typecheck": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:tokens": "eslint src --rule 'design-tokens/no-hardcoded-colors: error' --rule 'design-tokens/no-hardcoded-spacing: error' --rule 'design-tokens/use-design-tokens: warn' --rule 'design-tokens/no-hardcoded-design-values: error' && stylelint 'src/**/*.css' --ignore-pattern 'src/styles/tokens/**' --ignore-pattern 'src/styles/generated/**'",
    "lint:tokens:fix": "eslint src --fix --rule 'design-tokens/no-hardcoded-colors: error' --rule 'design-tokens/no-hardcoded-spacing: error' --rule 'design-tokens/use-design-tokens: warn' --rule 'design-tokens/no-hardcoded-design-values: error' && stylelint 'src/**/*.css' --fix --ignore-pattern 'src/styles/tokens/**' --ignore-pattern 'src/styles/generated/**'",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "npx playwright test tests/a11y/ --project=chromium",
    "test:a11y:report": "node scripts/contrast-report.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy:iis": "npm run build && powershell -ExecutionPolicy Bypass -File ../server/scripts/deploy-frontend.ps1 -SkipBuild"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.91.0",
    "@types/react-modal": "^3.16.3",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "formik": "^2.4.9",
    "joi": "^18.0.2",
    "react": "^19.2.4",
    "react-calendar": "^6.0.0",
    "react-dom": "^19.2.4",
    "react-modal": "^3.16.3",
    "react-router-dom": "^7.13.1",
    "react-select": "^5.10.2",
    "socket.io-client": "^4.8.3",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@axe-core/react": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.0.0",
    "axe-core": "^4.11.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^24.0.0",
    "pa11y-ci": "^4.1.0",
    "prettier": "^3.8.1",
    "storybook": "^8.6.18",
    "style-dictionary": "^4.4.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.21",
    "vite-imagetools": "^7.0.5",
    "vitest": "^2.0.0",
    "vitest-axe": "^0.1.0"
  }
}
