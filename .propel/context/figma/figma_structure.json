          "description": "See component_library.md for full specifications including props, variants, and states",
          "reference": ".propel/context/figma/components/component_library.md"
        },
        {
          "name": "Responsive Behavior",
          "breakpoints": {
            "mobile": { "range": "320px–767px", "columns": 4, "gutter": "16px", "nav": "BottomNav", "tables": "Card layout" },
            "tablet": { "range": "768px–1023px", "columns": 8, "gutter": "24px", "nav": "Sidebar (collapsed)", "tables": "Horizontal scroll" },
            "desktop": { "range": "1024px–1440px", "columns": 12, "gutter": "24px", "nav": "Sidebar (expanded)", "tables": "Full table" }
          }
        },
        {
          "name": "Edge Cases",
          "rules": [
            { "case": "Long patient name (>50 chars)", "handling": "Truncate with ellipsis, full name on hover tooltip" },
            { "case": "No available slots", "handling": "Display waitlist option + 'No slots available' message" },
            { "case": "Conflicting data", "handling": "Red badge + conflict resolution UI" },
            { "case": "Session timeout (15 min)", "handling": "Warning modal at 14 min + auto-logout" },
            { "case": "AI intake failure", "handling": "Fallback to manual mode + error banner" },
            { "case": "No-show grace period", "handling": "Disabled button + tooltip until 15 min after appt" },
            { "case": "Critical medication conflict", "handling": "Red alert banner + mandatory review before approval" }
          ]
        },
        {
          "name": "Accessibility Notes",
          "standard": "WCAG 2.2 AA",
          "requirements": [
            "Color contrast: 4.5:1 normal text, 3:1 large text/UI, 7:1 critical info",
            "Focus indicators: 2px primary-600 outline + 2px white inner ring on all interactive elements",
            "Touch targets: 44x44px minimum on mobile",
            "Tab order: Logical top-left to bottom-right reading order",
            "Focus trap: Modals and drawers trap focus within",
            "Screen readers: ARIA labels on all icon buttons, role=dialog on modals, role=alert on errors",
            "Keyboard: Escape closes modals, Tab/Shift+Tab navigation, Enter/Space activates"
          ]
        },
