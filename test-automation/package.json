{
  "name": "upaci-platform-test-automation",
  "version": "1.0.0",
  "description": "End-to-end test automation for UPACI platform using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:feature": "playwright test tests/",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:patient": "playwright test --project=e2e patient-complete-journey",
    "test:e2e:staff": "playwright test --project=e2e staff-queue-management",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "report": "playwright show-report",
    "test:accessibility": "playwright test --project=accessibility",
    "test:accessibility:report": "playwright test --project=accessibility --reporter=json",
    "codegen": "playwright codegen",
    "install:browsers": "playwright install",
    "load-test:booking": "k6 run load-tests/scenario_booking_flow.js",
    "load-test:upload": "k6 run load-tests/scenario_document_upload.js",
    "load-test:admin": "k6 run load-tests/scenario_admin_dashboard.js",
    "load-test:all": "k6 run load-tests/scenario_booking_flow.js && k6 run load-tests/scenario_document_upload.js && k6 run load-tests/scenario_admin_dashboard.js",
    "load-test:booking:report": "k6 run --out json=load-tests/reports/booking-results.json load-tests/scenario_booking_flow.js",
    "load-test:upload:report": "k6 run --out json=load-tests/reports/upload-results.json load-tests/scenario_document_upload.js",
    "load-test:admin:report": "k6 run --out json=load-tests/reports/admin-results.json load-tests/scenario_admin_dashboard.js"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e-testing",
    "test-automation",
    "healthcare"
  ],
  "author": "UPACI Test Team",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "axe-core": "^4.11.2",
    "typescript": "^5.3.0"
  }
}
